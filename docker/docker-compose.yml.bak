version: '3.8'

services:
  postgres:
    image: postgres:15-alpine
    container_name: medicare_db
    environment:
      POSTGRES_DB: medicare_db
      POSTGRES_USER: medicare_user
      POSTGRES_PASSWORD: medicare_password
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ../database/init.sql:/docker-entrypoint-initdb.d/init.sql
    networks:
      - medicare_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U medicare_user -d medicare_db"]
      interval: 5s
      timeout: 5s
      retries: 5

  backend:
    build: ../backend
    container_name: medicare_backend
    ports:
      - "3001:3000"
    environment:
      TZ=America/Sao_Paulo
      NODE_ENV: development
      PORT: 3000
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: medicare_db
      DB_USER: medicare_user
      DB_PASSWORD: medicare_password
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - ../backend:/app
      - /app/node_modules
    networks:
      - medicare_network
    command: npm run dev

  frontend:
    build: ../frontend
    container_name: medicare_frontend
    ports:
      - "3000:80"
    depends_on:
      - backend
    networks:
      - medicare_network

networks:
  medicare_network:
    driver: bridge

volumes:
  postgres_data:
